# ─────────────────────────────────────────────
# Converty OAuth2 Credentials
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

CONVERTY_CLIENT_ID=your_client_id_here
CONVERTY_CLIENT_SECRET=your_client_secret_here
CONVERTY_REDIRECT_URI=https://YOUR_HOSTED_URL/integrations/converty/oauth/callback

# ─────────────────────────────────────────────
# App Config
# ─────────────────────────────────────────────
PORT=3000
SESSION_SECRET=a_long_random_string_here

# ─────────────────────────────────────────────
# First Delivery Group API
# ─────────────────────────────────────────────
FIRST_DELIVERY_API_URL=https://www.firstdeliverygroup.com/api/v2
FIRST_DELIVERY_TOKEN=da7223c5-3f5e-402f-ab00-fb6e8cac7e5e

# ─────────────────────────────────────────────
# Tictac Delivery API
# ─────────────────────────────────────────────
TICTAC_API_URL=https://tic-tac-delivery.com/api/
TICTAC_CODE_API=your_code_api_here
TICTAC_CLE_API=your_cle_api_here

# ─────────────────────────────────────────────
# Meta Ads API
# ─────────────────────────────────────────────
META_ACCESS_TOKEN=your_meta_access_token_here
META_API_VERSION=v19.0


